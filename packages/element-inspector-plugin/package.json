{
  "name": "@react-native-scalable-devtools/element-inspector-plugin",
  "version": "0.0.4",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JoonDong2/react-native-scalable-devtools.git",
    "directory": "packages/element-inspector-plugin"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    }
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "README.ko.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && rollup -c",
    "prebuild": "yarn workspace @react-native-scalable-devtools/cli build:types",
    "pretypecheck": "yarn workspace @react-native-scalable-devtools/cli build:types",
    "typecheck": "tsc --noEmit",
    "test": "yarn typecheck"
  },
  "dependencies": {},
  "peerDependencies": {
    "react-native": "*",
    "@react-native-scalable-devtools/cli": "*",
    "ws": "*"
  },
  "devDependencies": {
    "@react-native-scalable-devtools/cli": "*"
  },
  "license": "MIT"
}
